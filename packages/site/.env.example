# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/aiusage

# Session cookie signing secret (min 32 chars)
SESSION_SECRET=change-me-to-a-random-string-at-least-32-chars

# AES-256-GCM key for encrypting device secrets (64 hex chars = 32 bytes)
DEVICE_SECRET_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# HMAC secret for IP hashing
IP_HASH_SECRET=change-me-to-a-random-string-at-least-32-chars

# Public site URL
SITE_URL=https://aiusage.jtanx.com

# Admin emails (comma-separated, auto-granted on verified email)
ADMIN_EMAILS=admin@example.com

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Linux Do OAuth
LINUX_DO_CLIENT_ID=
LINUX_DO_CLIENT_SECRET=
LINUX_DO_AUTHORIZATION_URL=https://connect.linux.do/oauth2/authorize
LINUX_DO_TOKEN_URL=https://connect.linux.do/oauth2/token
LINUX_DO_USERINFO_URL=https://connect.linux.do/api/user

# Cloudflare R2 (avatar storage)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=aiusage
R2_PUBLIC_URL=https://your-r2-public-url.example.com

# Amazon SES (optional - for email verification)
EMAIL_PROVIDER=ses
AWS_SES_REGION=us-west-2
AWS_SES_ACCESS_KEY_ID=
AWS_SES_SECRET_ACCESS_KEY=
EMAIL_FROM=AIUsage <noreply@jtanx.com>

# SMTP (optional - for email verification)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# EMAIL_FROM=noreply@aiusage.jtanx.com

# Email webhook (optional - alternative to SMTP; without it, verification links are printed to server logs)
# EMAIL_WEBHOOK_URL=https://your-mail-worker.example.com/send

# Logging
LOG_LEVEL=info
